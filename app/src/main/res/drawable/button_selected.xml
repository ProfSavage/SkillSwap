<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="false">
        <shape android:shape="rectangle">
            <solid android:color="#E4EBF0"/>
            <corners android:radius="15dp"/>
            <stroke android:width="1dp" android:color="#1C71E0"/>
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#AACAE7"/>
            <corners android:radius="15dp"/>
            <stroke android:width="1dp" android:color="#03B8FB"/>
        </shape>
    </item>

    <item android:state_hovered="true">
        <shape android:shape="rectangle">
            <solid android:color="#0E86F2"/>
            <corners android:radius="15dp"/>
            <stroke android:width="1dp" android:color="#053D7E"/>
        </shape>
    </item>
</selector>