<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:background="#C1CFDE"
    android:layout_height="match_parent"
    tools:context=".MainActivity">


    <FrameLayout
        android:layout_width="match_parent"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_gravity="center"
        android:layout_marginTop="20dp"
        android:outlineProvider="background"
        android:elevation="8dp"
        android:outlineAmbientShadowColor="@color/black"
        android:background="@drawable/background"
        android:layout_marginBottom="100dp"
        android:layout_height="50dp">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="match_parent"
            android:paddingTop="14dp"
            android:paddingLeft="15dp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="17dp"
            android:layout_height="match_parent"
            android:text="Skill Swap" />
    </FrameLayout>

    <androidx.cardview.widget.CardView
        android:layout_gravity="center"
        app:cardCornerRadius="40dp"
        app:cardBackgroundColor="#1A4CC1"
        android:layout_margin="10dp"
        android:layout_width="match_parent"
        android:layout_height="400dp" >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_gravity="center"
            android:layout_height="360dp" >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <Button
                    android:id="@+id/button"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="30dp"
                    android:onClick="categoriesPressed"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/button_selected"
                    android:text="Skill Categories" />

                <Button
                    android:id="@+id/button2"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginBottom="20dp"
                    android:onClick="skillPressed"
                    android:background="@drawable/button_selected"
                    android:text="Skill Listings" />

                <Button
                    android:id="@+id/button3"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:onClick="gotofavorite"
                    android:layout_marginBottom="30dp"
                    android:background="@drawable/button_selected"
                    android:text="bookmark" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.cardview.widget.CardView>
</LinearLayout>