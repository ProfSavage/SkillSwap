<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:background="#1A4CC1"
        android:layout_height="80dp">

    </FrameLayout>

    <androidx.cardview.widget.CardView
        android:layout_marginTop="20dp"
        android:layout_width="380dp"
        app:cardCornerRadius="30dp"
        android:elevation="100dp"
        android:outlineProvider="background"
        android:outlineAmbientShadowColor="@color/black"
        android:layout_gravity="center"
        android:background="@color/cardview_dark_background"
        android:layout_height="60dp" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:onClick="categoriesPressed">

            <View
                android:id="@+id/view"
                android:layout_gravity="center"
                android:layout_width="5dp"
                android:layout_margin="10dp"
                android:background="@color/black"
                android:layout_height="5dp"
                 />

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:srcCompat="@drawable/skillcate" />

            <TextView
                android:id="@+id/textView2"
                android:layout_margin="10dp"
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Skill Categories" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_marginTop="20dp"
        android:layout_width="380dp"
        app:cardCornerRadius="30dp"
        android:layout_gravity="center"
        android:elevation="100dp"
        android:outlineProvider="background"
        android:outlineAmbientShadowColor="#0F339E"
        android:background="@color/cardview_dark_background"
        android:layout_height="60dp" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:onClick="skillPressed">

            <View
                android:id="@+id/view1"
                android:layout_gravity="center"
                android:layout_width="5dp"
                android:layout_margin="10dp"
                android:background="@color/black"
                android:layout_height="5dp"
                />

            <ImageView
                android:id="@+id/imageView1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:srcCompat="@drawable/skilllist" />

            <TextView
                android:id="@+id/textView3"
                android:layout_margin="10dp"
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Skill Listings" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_marginTop="20dp"
        android:layout_width="380dp"
        app:cardCornerRadius="30dp"
        android:layout_gravity="center"
        android:elevation="100dp"
        android:outlineProvider="background"
        android:outlineAmbientShadowColor="#0F339E"
        android:background="@color/cardview_dark_background"
        android:layout_height="60dp" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <View
                android:id="@+id/view2"
                android:layout_gravity="center"
                android:layout_width="5dp"
                android:layout_margin="10dp"
                android:background="@color/black"
                android:layout_height="5dp"
                />

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                app:srcCompat="@drawable/skilllist" />

            <TextView
                android:id="@+id/textView4"
                android:layout_margin="10dp"
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Book Mark &amp; Favorite" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>


</LinearLayout>